rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ==================================================================================
       HELPER FUNCTIONS
       ================================================================================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'arkkahdarkkahd@gmail.com';
    }

    // Trip Cost
    function isTripCostParticipant(tripId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/artifacts/trip-cost/trips/$(tripId)).data.participantIds;
    }

    // Trip Planner
    function isTripPlannerParticipant(plannerId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/artifacts/trip-planner/planners/$(plannerId)).data.participantUids;
    }

    // Date Night
    function isDateNightParticipant() {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/artifacts/date-night/couples/main).data.participantUids;
    }

    // Trip Cost field update guard
    function allowedTripCostTopLevelUpdate() {
      let allowed = ['participants', 'participantIds', 'expenses', 'payments', 'updatedAt', 'name'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Conflict Tracker: member of a tracker (by UID or invited email)
    function isConflictTrackerMember(trackerId) {
      let tracker = get(/databases/$(database)/documents/artifacts/conflict-tracker/trackers/$(trackerId)).data;
      return isSignedIn() && (
        request.auth.uid in tracker.memberUids ||
        (tracker.memberEmails != null && request.auth.token.email in tracker.memberEmails)
      );
    }

    // Show Tracker: member of a list
    function isShowsListMember(listId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/artifacts/shows/lists/$(listId)).data.memberUids;
    }

    // Show Tracker: admin of a list (site admin OR list-level admin)
    function isShowsListAdmin(listId) {
      return isAdmin() || (isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/artifacts/shows/lists/$(listId)).data.adminUids);
    }

    /* ==================================================================================
       CALORIE TRACKER (LEGACY)
       ================================================================================== */

    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    /* ==================================================================================
       TRIP COST TOOL
       ================================================================================== */

    match /artifacts/trip-cost/users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /artifacts/trip-cost/trips/{tripId} {
      allow read: if isAdmin() || isTripCostParticipant(tripId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isTripCostParticipant(tripId) && allowedTripCostTopLevelUpdate());
    }

    match /artifacts/trip-cost/trips/{tripId}/audit/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /artifacts/trip-cost/trips/{tripId}/expenses/{expenseId} {
      allow read: if isAdmin() || isTripCostParticipant(tripId);
      allow create: if isTripCostParticipant(tripId) && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin() || (isTripCostParticipant(tripId) && resource.data.createdBy == request.auth.uid);
    }

    match /artifacts/trip-cost/trips/{tripId}/payments/{paymentId} {
      allow read: if isAdmin() || isTripCostParticipant(tripId);
      allow create: if isTripCostParticipant(tripId) && request.resource.data.payerId == request.auth.uid;
      allow update, delete: if isAdmin() || (isTripCostParticipant(tripId) && resource.data.payerId == request.auth.uid);
    }

    /* ==================================================================================
       TRIP PLANNER TOOL
       ================================================================================== */

    match /artifacts/trip-planner/planners/{plannerId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participantUids);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['ownerUid', 'participantUids'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.participantUids.size() == 1
        && request.resource.data.participantUids[0] == request.auth.uid;

      allow update: if
        isAdmin()
        || (isSignedIn()
            && request.auth.uid in resource.data.participantUids
            && !request.resource.data.diff(resource.data).changedKeys().hasAny(['ownerUid', 'participantUids', 'costTrackerId'])
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'startDate', 'endDate', 'timezone', 'settings', 'updatedAt']))
        || (isSignedIn()
            && request.auth.uid == resource.data.ownerUid
            && !request.resource.data.diff(resource.data).changedKeys().hasAny(['ownerUid'])
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'name', 'startDate', 'endDate', 'timezone', 'settings', 'updatedAt',
                'participantUids', 'participants', 'lastModifiedBy', 'costTrackerId'
            ]));

      allow delete: if isAdmin();
    }

    match /artifacts/trip-planner/planners/{plannerId}/events/{eventId} {
      allow read: if isAdmin() || isTripPlannerParticipant(plannerId);
      allow create, update, delete: if isAdmin() || isTripPlannerParticipant(plannerId);
    }

    match /artifacts/trip-planner/planners/{plannerId}/activityIdeas/{ideaId} {
      allow read: if isAdmin() || isTripPlannerParticipant(plannerId);
      allow create, update, delete: if isAdmin() || isTripPlannerParticipant(plannerId);
    }

    match /artifacts/trip-planner/planners/{plannerId}/changelog/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    /* ==================================================================================
       DATE NIGHT ROULETTE TOOL
       ================================================================================== */

    match /artifacts/date-night/couples/{coupleId} {
      allow read: if isAdmin() || isDateNightParticipant();
      allow create, update, delete: if isAdmin();
    }

    match /artifacts/date-night/settings/{settingId} {
      allow read, write: if isAdmin() || isDateNightParticipant();
    }

    match /artifacts/date-night/dates/{docId} {
      allow read, create, update, delete: if isAdmin() || isDateNightParticipant();
    }

    match /artifacts/date-night/modifiers/{docId} {
      allow read, create, update, delete: if isAdmin() || isDateNightParticipant();
    }

    match /artifacts/date-night/rolls/{docId} {
      allow read, create, update, delete: if isAdmin() || isDateNightParticipant();
    }

    /* ==================================================================================
       CONFLICT TRACKER TOOL
       ================================================================================== */

    match /artifacts/conflict-tracker/trackers/{trackerId} {
      allow read: if isAdmin() || isConflictTrackerMember(trackerId);

      allow create: if isSignedIn()
        && request.resource.data.personAUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.createdBy == request.auth.uid;

      // Members can update (add custom tags, claim personB side, etc.)
      allow update: if isAdmin() || isConflictTrackerMember(trackerId);

      allow delete: if isAdmin();
    }

    match /artifacts/conflict-tracker/trackers/{trackerId}/conflicts/{conflictId} {
      allow read: if isAdmin() || isConflictTrackerMember(trackerId);
      allow create: if isConflictTrackerMember(trackerId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() || isConflictTrackerMember(trackerId);
      allow delete: if isAdmin() || isConflictTrackerMember(trackerId);
    }

    match /artifacts/conflict-tracker/trackers/{trackerId}/conflicts/{conflictId}/reflections/{reflectionId} {
      allow read: if isAdmin() || isConflictTrackerMember(trackerId);
      allow create, update: if isConflictTrackerMember(trackerId)
        && request.resource.data.authorUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    /* ==================================================================================
       SHOW TRACKER
       ================================================================================== */

    // Lists
    match /artifacts/shows/lists/{listId} {
      // Read: any member
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.memberUids);

      // Create: any authed user; must set themselves as owner, member, and admin
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && request.auth.uid in request.resource.data.adminUids;

      // Update: admins freely; OR self-add via invite flow (only allowed change is adding self)
      allow update: if isAdmin()
        || isShowsListAdmin(listId)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberUids', 'updatedAt'])
            && request.auth.uid in request.resource.data.memberUids
            && !(request.auth.uid in resource.data.memberUids));

      // Delete: list admin only
      allow delete: if isAdmin() || isShowsListAdmin(listId);
    }

    // Shows
    match /artifacts/shows/shows/{showId} {
      allow read: if isAdmin() || isShowsListMember(resource.data.listId);
      allow create: if isShowsListMember(request.resource.data.listId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin() || isShowsListMember(resource.data.listId);
      allow delete: if isAdmin() || isShowsListAdmin(resource.data.listId);
    }

    // Pending invites
    match /artifacts/shows/pendingInvites/{inviteId} {
      // Read: site admin, or the invited user (for self-processing on sign-in)
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.email == request.auth.token.email);

      // Create: only list admins can invite
      allow create: if isShowsListAdmin(request.resource.data.listId);

      // Delete: site admin, list admin, or the invited user consuming their own invite
      allow delete: if isAdmin()
        || isShowsListAdmin(resource.data.listId)
        || (isSignedIn() && resource.data.email == request.auth.token.email);

      allow update: if false;
    }

  }
}
